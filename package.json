{
  "name": "fintrack-backend",
  "version": "0.1.0",
  "private": true,
  "description": "FinTrack backend.",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "guardrails": "tsx scripts/architecture-guardrails.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.41.0",
    "bullmq": "^5.30.0",
    "dotenv": "^16.4.7",
    "eventemitter2": "^6.4.9",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "lru-cache": "^11.0.2",
    "opossum": "^8.1.4",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "@prisma/adapter-pg": "^7.8.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
