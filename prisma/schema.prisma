generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}


model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  phone        String?  @unique
  passwordHash String   @map("password_hash")
  tier         Tier     @default(FREE)
  createdAt    DateTime @default(now()) @map("created_at")
  deletionScheduledAt DateTime? @map("deletion_scheduled_at")

  accounts              Account[]
  budgets               Budget[]
  reports               Report[]
  subscription          Subscription?
  merchantPreferences   UserMerchantPreference[]
  billingEvents         BillingEvent[]
  deviceTokens          DeviceToken[]
  notificationPreference NotificationPreference?

  @@map("users")
}

model Account {
  id                  String        @id @default(uuid()) @db.Uuid
  userId              String        @map("user_id") @db.Uuid
  bankName            String        @map("bank_name")
  accountLast4        String        @map("account_last4")
  accountType         AccountType   @map("account_type")
  captureMethod       CaptureMethod @map("capture_method")
  gmailConnected      Boolean       @default(false) @map("gmail_connected")
  gmailTokenEnc       String?       @map("gmail_token_enc")
  balanceKobo         BigInt        @default(0) @map("balance_kobo")
  lastTransactionDate DateTime?     @map("last_transaction_date")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([userId])
  @@map("accounts")
}

model Transaction {
  id              String          @default(uuid()) @db.Uuid
  accountId       String          @map("account_id") @db.Uuid
  amountKobo      BigInt          @map("amount_kobo")
  type            TransactionType
  merchantName    String          @map("merchant_name")
  categoryId      String          @map("category_id") @db.Uuid
  transactionDate DateTime        @map("transaction_date")
  source          CaptureSource
  parserId        String?         @map("parser_id") @db.Uuid
  rawSnippetEnc   String?         @map("raw_snippet_enc")
  isVerified      Boolean         @default(false) @map("is_verified")
  idempotencyKey  String          @map("idempotency_key")
  createdAt       DateTime        @default(now()) @map("created_at")

  account  Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category Category           @relation(fields: [categoryId], references: [id])
  events   TransactionEvent[]
  alerts   BudgetAlert[]

  @@id([id, transactionDate])
  @@unique([idempotencyKey, transactionDate])
  @@index([accountId, transactionDate])
  @@index([categoryId, transactionDate])
  @@map("transactions")
}

model TransactionEvent {
  id              String   @id @default(uuid()) @db.Uuid
  transactionId   String   @map("transaction_id") @db.Uuid
  transactionDate DateTime @map("transaction_date")
  type            String
  payload         Json
  previousHash    String   @map("previous_hash")
  hash            String
  createdAt       DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId, transactionDate], references: [id, transactionDate], onDelete: Cascade)

  @@index([transactionId, createdAt])
  @@map("transaction_events")
}

model BudgetAlert {
  id              String   @id @default(uuid()) @db.Uuid
  transactionId   String   @map("transaction_id") @db.Uuid
  transactionDate DateTime @map("transaction_date")
  budgetId        String   @map("budget_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId, transactionDate], references: [id, transactionDate], onDelete: Cascade)
  budget      Budget      @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@unique([transactionId, budgetId])
  @@index([userId])
  @@map("budget_alerts")
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  icon         String
  createdAt    DateTime @default(now()) @map("created_at")

  transactions        Transaction[]
  keywords            CategoryKeyword[]
  merchantMappings    MerchantCategoryMap[]
  merchantPreferences UserMerchantPreference[]
  budgets             Budget[]

  @@map("categories")
}

model CategoryKeyword {
  id         String   @id @default(uuid()) @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  keyword    String
  createdAt  DateTime @default(now()) @map("created_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, keyword])
  @@index([keyword])
  @@map("category_keywords")
}

model MerchantCategoryMap {
  id                  String                @id @default(uuid()) @db.Uuid
  merchantFingerprint String                @unique @map("merchant_fingerprint")
  categoryId          String                @map("category_id") @db.Uuid
  source              MerchantMappingSource @default(SEEDED)
  confidence          Int                   @default(100)
  confirmedByUsers    Int                   @default(0) @map("confirmed_by_users")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("merchant_category_maps")
}

model UserMerchantPreference {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  merchantFingerprint String   @map("merchant_fingerprint")
  categoryId          String   @map("category_id") @db.Uuid
  correctionCount     Int      @default(1) @map("correction_count")
  lastCorrectedAt     DateTime @default(now()) @map("last_corrected_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, merchantFingerprint])
  @@index([categoryId])
  @@map("user_merchant_preferences")
}

model Budget {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  categoryId String     @map("category_id") @db.Uuid
  limitKobo  BigInt     @map("limit_kobo")
  periodType PeriodType @map("period_type")
  createdAt  DateTime   @default(now()) @map("created_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category      @relation(fields: [categoryId], references: [id])
  alerts   BudgetAlert[]

  @@index([userId, periodType])
  @@index([categoryId])
  @@map("budgets")
}

model ParserPattern {
  id               String        @id @default(uuid()) @db.Uuid
  senderDomain     String        @unique @map("sender_domain")
  bankName         String        @map("bank_name")
  status           PatternStatus
  patterns         Json
  aiGenerated      Boolean       @map("ai_generated")
  confirmedByUsers Int           @default(0) @map("confirmed_by_users")
  version          Int           @default(1)
  lastValidated    DateTime      @map("last_validated")
  createdAt        DateTime      @default(now()) @map("created_at")

  @@map("parser_patterns")
}

model Report {
  id            String     @id @default(uuid()) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  periodType    PeriodType @map("period_type")
  periodStart   DateTime   @map("period_start")
  periodEnd     DateTime   @map("period_end")
  isStale       Boolean    @default(false) @map("is_stale")
  schemaVersion Int        @default(1) @map("schema_version")
  data          Json
  generatedAt   DateTime   @default(now()) @map("generated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodType, periodStart])
  @@index([userId, periodType])
  @@map("reports")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  requestId    String   @map("request_id")
  userId       String   @map("user_id") @db.Uuid
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  ipAddress    String   @map("ip_address")
  userAgent    String   @map("user_agent")
  metadata     Json
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("audit_logs")
}

model Subscription {
  id                     String             @id @default(uuid()) @db.Uuid
  userId                 String             @unique @map("user_id") @db.Uuid
  provider               BillingProvider
  providerCustomerId     String             @map("provider_customer_id")
  providerSubscriptionId String             @unique @map("provider_subscription_id")
  providerPlanId         String             @map("provider_plan_id")
  status                 SubscriptionStatus
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelledAt            DateTime?          @map("cancelled_at")
  gracePeriodEndsAt      DateTime?          @map("grace_period_ends_at")
  trialEndsAt            DateTime?          @map("trial_ends_at")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([status, gracePeriodEndsAt])
  @@map("subscriptions")
}

model BillingEvent {
  id              String          @id @default(uuid()) @db.Uuid
  provider        BillingProvider
  providerEventId String          @unique @map("provider_event_id")
  eventType       String          @map("event_type")
  normalizedType  String          @map("normalized_type")
  userId          String?         @map("user_id") @db.Uuid
  anonymizedUserId String?        @map("anonymized_user_id") @db.Uuid
  payload         Json
  processed       Boolean         @default(false)
  processedAt     DateTime?       @map("processed_at")
  processingError String?         @map("processing_error")
  createdAt       DateTime        @default(now()) @map("created_at")

  user            User?           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([processed, createdAt])
  @@map("billing_events")
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  eventType   String    @map("event_type")
  payload     Json
  createdAt   DateTime  @default(now()) @map("created_at")
  publishedAt DateTime? @map("published_at")
  attempts    Int       @default(0)

  @@index([publishedAt, attempts])
  @@map("outbox_events")
}

enum Tier {
  FREE
  PRO
}

enum AccountType {
  CURRENT
  SAVINGS
  WALLET
}

enum CaptureMethod {
  EMAIL
  MANUAL
  SMS
  MONO
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum CaptureSource {
  EMAIL
  MANUAL
  SMS
  MONO
}

enum PeriodType {
  WEEKLY
  MONTHLY
}

enum PatternStatus {
  LEARNING
  STABLE
}

enum BillingProvider {
  PAYSTACK
  MONNIFY
}

enum SubscriptionStatus {
  ACTIVE
  GRACE_PERIOD
  CANCELLED
  EXPIRED
}

enum MerchantMappingSource {
  SEEDED
  USER_CORRECTION
  AI_CONFIRMED
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  platform  String   @map("platform") // 'ANDROID' | 'IOS'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model NotificationPreference {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @unique @map("user_id") @db.Uuid
  budgetAlerts         Boolean  @default(true) @map("budget_alerts")
  paymentFailures      Boolean  @default(true) @map("payment_failures")
  subscriptionExpiring Boolean  @default(true) @map("subscription_expiring")
  weeklyReports        Boolean  @default(true) @map("weekly_reports")
  monthlyReports       Boolean  @default(true) @map("monthly_reports")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

